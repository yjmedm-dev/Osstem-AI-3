# Claude API
ANTHROPIC_API_KEY=your_api_key_here

# 1C:Enterprise OData 접속 정보 (우즈베키스탄 법인)
ONEC_URL=http://192.168.1.10/UZ_Base
ONEC_USER=admin
ONEC_PASS=your_password_here
ONEC_ORG=ООО Оссем Узбекистан   # 1C 내 조직명 (python main.py 1c-orgs 로 확인)
ONEC_CURRENCY=UZS
ONEC_RATE=0.086                  # UZS → KRW 환율 (1 UZS = 0.086 KRW)

# 데이터베이스 (운영 환경에서만 설정)
# DATABASE_URL=postgresql://user:password@host:5432/osstem_ai

# 경로 설정 (기본값 사용 시 생략 가능)
# DATA_INPUT_DIR=data/input
# DATA_PROCESSED_DIR=data/processed
# DATA_REFERENCE_DIR=data/reference
